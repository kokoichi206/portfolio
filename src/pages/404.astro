---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 | Not Found">
  <main class="mx-auto flex min-h-[70vh] max-w-6xl flex-col items-center justify-center px-4 text-center">
    <p class="text-6xl font-bold text-sakura-400">404</p>
    <h1 class="mt-4 text-2xl font-bold text-neutral-100">Page not found</h1>
    <p class="mt-2 text-neutral-500">The page you're looking for doesn't exist.</p>
    <a
      href="/"
      class="mt-8 rounded-lg border border-sakura-400/50 px-6 py-2 text-sm text-sakura-400 transition-colors hover:bg-sakura-400/10"
    >
      Back to home
    </a>
  </main>
</Layout>
